{
  "version": 2,
  "builds": [
    {
      "src": "public/brochure.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/scrape.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/scrape",
      "dest": "/api/scrape.js"
    },
    {
      "src": "/brochure",
      "dest": "/public/brochure.html"
    },
    {
      "src": "/",
      "dest": "/public/brochure.html"
    }
  ]
}
